// Makes a new chunked-reader.  Use this stream once created, as it
// peeks the stream and it corrupts the original stream.  It works as
// a buffered stream when the content stream is not chunked.
func New_chunked_reader(r io.Reader) *chunked_reader {
	var length, _, sig, _ = lookat_chunk_header(r)
	var chunked chunked_type
	switch {
	case length == 0:
		chunked = NOT_CHUNKED
	case sig == "":
		chunked = CHUNKED_HTTP1
	default:
		chunked = CHUNKED_AWS
	}
	return &chunked_reader{r: r1, chunked: chunked}
}

