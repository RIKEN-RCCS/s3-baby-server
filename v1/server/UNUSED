func (bbs *Bb_server) copy_object_by_linking(ctx context.Context, object string, part int, upload_id string, source string, extent *[2]int64, info *Meta_info, check copy_checks) (*time.Time, *Aws_s3_error) {
	var location = "/" + target
	bb_assert(extent == nil)

	var rid int64 = get_request_id(ctx)
	var scratchkey = bbs.make_scratch_suffix(rid)
	defer bbs.discharge_scratch_suffix(rid)

	// TARGET is the copy destination.  It can be either an object or
	// a MPUL part file.

	var target string
	if part != 0 {
		target = make_mpul_part_name(object, part)
	} else {
		target = object
	}

