	bb_assert(stat != nil)

	// Update MPUL catatlog information.

	if part != 0 {
		var size = stat.Size()
		var mtime = stat.ModTime()
		var csums = base64.StdEncoding.EncodeToString(csum2)
		var partinfo = &Mpul_part{
