{
  "name": "multipart",
  "date": "2025-09-25",
  "NOTE": ["It should start with an empty pool directory.",
	   "It needs a file \"file-4m.txt\" on the client side.",
	   "Place some dot-files to check they are not listed.",
	   "./files directory exits and populated by some files."],
  "test": [
{
  "ID": 801,
  "step": "Make a 'mybucket1' bucket.",
  "pre": "Buckets={}",
  "name": "CreateBucket",
  "kind": "s3api",
  "operation": "aws s3api create-bucket --no-cli-pager --bucket mybucket1",
  "status": 0,
  "outcome1": {"Location": "/mybucket1"},
  "outcome2": null
},
{
  "ID": 802,
  "step": "Upload an 10MB file as 'data-001.txt'.",
  "name": "PutObject",
  "kind": null,
  "operation": "aws s3api put-object --no-cli-pager --bucket mybucket1 --key data-001.txt --body ./data-10m.txt",
  "status": 0,
  "outcome1": {
    "ETag": "#|etag|",
    "ChecksumCRC64NVME": "#|csum|",
    "ChecksumType": "FULL_OBJECT"
  },
  "outcome2": null
},
{
  "ID": 1,
  "step": "Start a multipart upload.",
  "name": "CreateMultipartUpload",
  "kind": null,
  "pre": "Files = {}",
  "operation": "aws s3api create-multipart-upload --no-cli-pager --bucket mybucket1 --key data-101.txt",
  "status": 0,
  "record": [{"upload1-id": ["UploadId"]}],
  "outcome1": {
    "Bucket": "mybucket1",
    "Key": "data-101.txt",
    "UploadId": "#_"
  },
  "outcome2": null
},
{
  "ID": 2,
  "step": "Upload Part.",
  "name": "UploadPart",
  "kind": null,
  "record": [{"part1-etag": ["ETag"]}],
  "operation": "aws s3api upload-part --no-cli-pager --bucket mybucket1 --key data-101.txt --upload-id #upload1-id --part-number 1 --body data-10m.txt",
  "status": 0,
  "outcome1": {
    "ETag": "#|etag|",
    "ChecksumCRC64NVME": "#|csum|"
  },
  "outcome2": null
},
{
  "ID": 3,
  "step": "Upload Part Copy.",
  "name": "UploadPartCopy",
  "kind": null,
  "record": [{"part2-etag": ["CopyPartResult", "ETag"]}],
  "operation": "aws s3api upload-part-copy --no-cli-pager --bucket mybucket1 --key data-101.txt --upload-id #upload1-id --part-number 2 --copy-source mybucket1/data-001.txt",
  "status": 0,
  "outcome1": {
    "CopyPartResult": {
      "ETag": "#|etag|",
      "LastModified": "#|datetime|"
    }
  },
  "outcome2": null
},
{
  "ID": 4,
  "step": "List Parts.",
  "name": "ListParts",
  "kind": null,
  "operation": "aws s3api list-parts --no-cli-pager --bucket mybucket1 --key data-101.txt --upload-id #upload1-id",
  "status": 0,
  "outcome1": {
    "Parts": [
      {
        "PartNumber": "#_",
        "LastModified": "#|datetime|",
        "ETag": "#|etag|",
        "ChecksumCRC64NVME": "#|csum|",
        "Size": "#_"
      }
    ],
    "ChecksumAlgorithm": "#_",
    "Initiator": "#_",
    "Owner": "#_",
    "StorageClass": "STANDARD",
    "ChecksumType": "#_"
  },
  "outcome2": null
},
{
  "ID": 5,
  "step": "List Multipart Uploads.",
  "name": "ListMultipartUploads",
  "kind": null,
  "operation": "aws s3api list-multipart-uploads --no-cli-pager --bucket mybucket1",
  "status": 0,
  "outcome1": {
    "Uploads": [
      {
        "UploadId": "#_",
        "Key": "#_",
        "Initiated": "#|datetime|",
        "StorageClass": "STANDARD"
      }
    ],
    "RequestCharged": null,
    "Prefix": ""
  },
  "outcome2": null
},
{
  "ID": 6,
  "step": "",
  "name": "CompleteMultipartUpload",
  "kind": null,
  "operation": "aws s3api complete-multipart-upload --no-cli-pager --bucket mybucket1 --key data-101.txt --upload-id #upload1-id --multipart-upload '{\"Parts\":[{\"ETag\":\"#part1-etag\",\"PartNumber\":1},{\"ETag\":\"#part2-etag\",\"PartNumber\":2}]}'",
  "status": 0,
  "outcome1": {
    "Bucket": "mybucket1",
    "Key": "data-101.txt",
    "ETag": "#|etag|"
  },
  "outcome2": null
},
{
  "ID": 7,
  "step": "Get attributes of 'data-101.txt'.",
  "name": "GetObjectAttributes",
  "kind": null,
  "pre": "Files = {'data-001.txt', 'data-002.txt', 'data-003.txt'}",
  "operation": "aws s3api get-object-attributes --no-cli-pager --bucket mybucket1 --key data-101.txt --object-attributes \"ETag\" \"Checksum\" \"ObjectParts\" \"StorageClass\" \"ObjectSize\"",
  "status": 0,
  "outcome1": {
    "LastModified": "#|datetime|",
    "ETag": "#|etag|",
    "Checksum": {
      "ChecksumCRC64NVME": "#|csum|"
    },
    "ObjectParts": {
      "TotalPartsCount": 1,
      "NextPartNumberMarker": 1,
      "MaxParts": 10000,
      "IsTruncated": false,
      "Parts": [
        {
          "PartNumber": 1,
          "Size": "#_"
        }
      ]
    },
    "StorageClass": "STANDARD",
    "ObjectSize": "#_"
  },
  "outcome2": null
},
{
  "ID": 8,
  "step": "Start a 2nd multipart upload on the same file.",
  "name": "CreateMultipartUpload",
  "kind": null,
  "record": [{"upload2-id": ["UploadId"]}],
  "operation": "aws s3api create-multipart-upload --no-cli-pager --bucket mybucket1 --key data-102.txt",
  "status": 0,
  "outcome1": {
    "Bucket": "mybucket1",
    "Key": "data-102.txt",
    "UploadId": "#_"
  },
  "outcome2": null
},
{
  "ID": 9,
  "step": "Abort the 2nd multipart upload.",
  "name": "AbortMultipartUpload",
  "kind": null,
  "operation": "aws s3api abort-multipart-upload --no-cli-pager --bucket mybucket1 --key multipart.txt --upload-id #upload2-id",
  "status": 0,
  "outcome1": {},
  "outcome2": null
},
{
  "ID": 10,
  "step": "Check aborted multipart uploads.",
  "name": "ListMultipartUploads",
  "kind": null,
  "operation": "aws s3api list-multipart-uploads --no-cli-pager --bucket mybucket1",
  "status": 0,
  "outcome1": {
    "RequestCharged": null,
    "Prefix": ""
  },
  "outcome2": null
},
{
  "ID": 901,
  "step": "Delete two files, 'data-001.txt' and 'data-101.txt'",
  "name": "DeleteObjects",
  "kind": null,
  "operation": "aws s3api delete-objects --no-cli-pager --bucket mybucket1 --delete '{\"Objects\":[{\"Key\":\"data-001.txt\"},{\"Key\":\"data-101.txt\"}],\"Quiet\":false}'",
  "status": 0,
  "outcome1": {
    "Deleted": [
      {
        "Key": "data-[01]01.txt"
      }
    ]
  },
  "outcome2": null
},
{
  "ID": 902,
  "step": "Delete bucket 'mybucket1'.",
  "pre": "Files = {}",
  "name": "DeleteBucket",
  "kind": null,
  "operation": "aws s3api delete-bucket --no-cli-pager --bucket mybucket1",
  "status": 0,
  "outcome1": {},
  "outcome2": null
},
{
  "ID": 903,
  "step": "Check 'mybucket1' is deleted.",
  "name": "DeleteBucket",
  "kind": null,
  "operation": "aws s3api list-buckets --no-cli-pager",
  "status": 0,
  "outcome1": {
    "Buckets": [],
    "Owner": null,
    "Prefix": null
  },
  "outcome2": null
}
]
}
