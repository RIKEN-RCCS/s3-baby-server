  "name": "CopyObject",
  "kind": null,
  "operation": "aws s3api copy-object --bucket mybucket1 --key data-003.txt --copy-source mybucket1/data-001.txt",
  "status": "200 OK",
  "outcome1": {
    "CopyObjectResult": {
      "ETag": "\"b5cfa9d6c8febd618f91ac2843d50a1c\"",
      "LastModified": "2025-08-19T08:45:32.882000+00:00"
    }
  },
  "outcome2": null
},
{
  "ID": 10,
  "step": "List objects by V2.",
  "name": "ListObjectsV2",
  "kind": null,
  "operation": "aws s3api list-objects-v2 --bucket mybucket1",
  "status": "200 OK",
  "outcome1": {
    "Contents": [
      {
        "Key": "data-001.txt",
        "LastModified": "2025-08-19T08:42:29.498000+00:00",
        "ETag": "\"b5cfa9d6c8febd618f91ac2843d50a1c\"",
        "Size": 4194304,
        "StorageClass": "STANDARD"
      },
      {
        "Key": "data-002.txt",
