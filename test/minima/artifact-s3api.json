        }
      }
    ],
    "RequestCharged": null,
    "Prefix": ""
  },
  "outcome2": null
},
{
  "ID": 8,
  "step": "Copy in a bucket, 'data-001.txt' to 'data-002.txt'.",
  "name": "CopyObject",
  "kind": null,
  "operation": "aws s3api copy-object --bucket mybucket1 --key data-002.txt --copy-source mybucket1/data-001.txt",
  "status": "200 OK",
  "outcome1": {
    "CopyObjectResult": {
      "ETag": "\"b5cfa9d6c8febd618f91ac2843d50a1c\"",
      "LastModified": "2025-08-19T08:45:32.882000+00:00"
    }
  },
  "outcome2": null
