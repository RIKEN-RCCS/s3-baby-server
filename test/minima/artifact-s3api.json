        "Size": 4194304,
        "StorageClass": "STANDARD"
      }
    ],
    "RequestCharged": null,
    "Prefix": ""
  },
  "outcome2": null
},
{
  "ID": 11,
  "step": "Put a tag on 'data-001.txt'.",
  "name": "PutObjectTagging",
  "kind": null,
  "operation": "aws s3api put-object-tagging --bucket mybucket1 --key data-001.txt --tagging \"TagSet=[{Key=TestKey,Value=TestValue}]\"",
  "status": "200 OK",
  "outcome1": {},
  "outcome2": null
},
{
