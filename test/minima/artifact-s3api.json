  "name": "GetObjectTagging",
  "kind": null,
  "operation": "aws s3api get-object-tagging --bucket mybucket1 --key data-001.txt",
  "status": "200 OK",
  "outcome1": {
    "TagSet": [
      {
        "Key": "TestKey",
        "Value": "TestValue"
      }
    ]
  },
  "outcome2": null
},
{
  "ID": 13,
  "step": "Delete tags on 'data-001.txt'.",
  "name": "DeleteObjectTagging",
  "kind": null,
  "operation": "aws s3api delete-object-tagging --bucket mybucket1 --key data-001.txt",
  "status": "204 NoContent",
  "outcome1": {},
  "outcome2": null
},
{
  "ID": 14,
  "step": "Get tags to check tags are removed.",
  "name": "GetObjectTagging",
  "kind": null,
  "operation": "aws s3api get-object-tagging --bucket mybucket1 --key data-001.txt",
  "status": "200 OK",
