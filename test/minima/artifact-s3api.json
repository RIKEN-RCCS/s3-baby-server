{
  "name": "s3api",
  "date": "2025-09-25",
  "NOTE": ["It assumes start with an empty pool directory.",
	   "Needs existence of files: 'data-04m.txt'.",
	   "Works in a bucket: 'mybucket'.",
	   "Uses files: 'data-001.txt', 'data-002.txt', 'data-003.txt'.",
	   "Leaves files: 'data-101.txt'."],
  "test": [
{
  "ID": 1,
  "step": "Make a 'mybucket1' bucket",
  "pre": "Start with an empty pool directory.",
  "name": "CreateBucket",
  "kind": "s3api",
  "operation": "aws s3api create-bucket --bucket mybucket1",
  "status": "200 OK",
  "outcome1": {"Location": "/mybucket1"},
  "outcome2": null
},
{
  "ID": 2,
  "step": "Check 'mybucket1' existance.",
  "name": "HeadBucket",
  "kind": null,
  "operation": "aws s3api head-bucket --bucket mybucket1",
  "status": "200 OK",
  "outcome1": {"AccessPointAlias": false},
  "outcome2": null
},
{
  "ID": 3,
  "step": "List buckets.  It finds 'mybucket1'.",
  "name": "ListBuckets",
  "kind": null,
  "operation": "aws s3api list-buckets",
  "status": "200 OK",
  "outcome1": {
    "Buckets": [
      {
        "Name": "mybucket1",
        "CreationDate": "#datetime"
      }
    ],
    "Owner": null,
    "Prefix": null
  },
  "outcome2": null
},
{
  "ID": 4,
  "step": "Upload a 4MB file as 'data-001.txt'.",
  "name": "PutObject",
  "kind": null,
  "operation": "aws s3api put-object --bucket mybucket1 --key data-001.txt --body ./data-04m.txt",
  "status": "200 OK",
  "outcome1": {
    "ETag": "[[:xdigit:]]{32}",
    "ChecksumCRC64NVME": "[a-zA-Z0-9=]{12}",
    "ChecksumType": "FULL_OBJECT"
  },
  "outcome2": null
},
{
  "ID": 5,
  "step": "Take information on 'data-001.txt'.",
  "name": "HeadObject",
  "kind": null,
  "operation": "aws s3api head-object --bucket mybucket1 --key data-001.txt",
  "status": "200 OK",
  "outcome1": {
    "AcceptRanges": "bytes",
    "LastModified": "2025-08-19T08:42:29+00:00",
    "ContentLength": 4194304,
    "ETag": "\"b5cfa9d6c8febd618f91ac2843d50a1c\"",
    "ContentType": "binary/octet-stream",
    "Metadata": {}
  },
  "outcome2": null
},
{
  "ID": 6,
  "step": "Download a 'data-001.txt' file as 'data-101.txt'.",
  "name": "GetObject",
  "kind": null,
  "operation": "aws s3api get-object --bucket mybucket1 --key data-001.txt data-101.txt",
  "status": "200 OK",
  "outcome1": {
    "AcceptRanges": "bytes",
    "LastModified": "2025-08-19T08:42:29+00:00",
    "ContentLength": 4194304,
    "ETag": "\"b5cfa9d6c8febd618f91ac2843d50a1c\"",
    "ChecksumCRC64NVME": "BDJX5ole/O0=",
    "ChecksumType": "FULL_OBJECT",
    "ContentType": "binary/octet-stream",
    "Metadata": {}
  },
  "outcome2": null
},
{
  "ID": 7,
  "step": "List objects in 'mybucket1'.",
  "name": "ListObjects",
  "kind": null,
  "operation": "aws s3api list-objects --bucket mybucket1",
  "status": "200 OK",
  "outcome1": {
    "Contents": [
      {
        "Key": "data-001.txt",
        "LastModified": "2025-08-19T08:42:29.498000+00:00",
        "ETag": "\"b5cfa9d6c8febd618f91ac2843d50a1c\"",
        "Size": 4194304,
        "StorageClass": "STANDARD",
        "Owner": {
          "DisplayName": "minio",
