  "name": "GetObjectAttributes",
  "kind": null,
  "operation": "aws s3api get-object-attributes --bucket mybucket1 --key data-001.txt --object-attributes \"ETag\" \"Checksum\" \"ObjectParts\" \"StorageClass\" \"ObjectSize\"",
