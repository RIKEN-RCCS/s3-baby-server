{
  "name": "multipart",
  "date": "2025-09-25",
  "NOTE": ["It should start with an empty pool directory.",
	   "Make a file \"file-5m.txt\" on the client side.",
	   "Place some dot-files to check they are not listed.",
	   "./files directory exits and populated by some files."],
  "test": [
{
  "ID": 1,
  "step": "Make a 'mybucket1' bucket.",
  "pre": "Buckets={}",
  "name": "CreateBucket",
  "kind": "s3api",
  "operation": "aws s3api create-bucket --no-cli-pager --bucket mybucket1",
  "status": 0,
  "outcome1": {"Location": "/mybucket1"},
  "outcome2": null
},
{
  "ID": 2,
  "step": "Start a multipart upload.",
  "name": "CreateMultipartUpload",
  "kind": null,
  "pre": "Files = {}",
