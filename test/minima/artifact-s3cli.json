{
  "name": "s3cli",
  "date": "2025-09-25",
  "NOTE": ["It should be started with an empty pool directory.",
	   "It needs files on the client: {'data-04m.txt', data-10m.txt'},",
	   "and files in './datafiles': {'data-00[1234].txt'}."],
  "test": [
{
  "ID": 1,
  "step": "Display a list of buckets, which is initially empty.  Check no dot-files are listed.",
  "name": "server-connection",
  "kind": "basic",
  "operation": "aws s3api list-buckets",
  "status": 0,
  "outcome1": {"Buckets": [],
	       "Owner": null,
	       "Prefix": null},
  "outcome2": null
},
{
  "ID": 2,
  "step": "Create a bucket named 'mybucket'.",
  "name": "MB",
  "kind": "s3 command",
  "operation": "aws s3 mb --no-progress s3://mybucket",
  "status": 0,
  "outcome1": null,
  "outcome2": ["make_bucket: mybucket"]
},
{
  "ID": 3,
  "step": "Displays a list of buckets.  There is one 'mybucket'.",
  "name": "LS",
  "kind": "s3 command",
  "operation": "aws s3 ls --no-progress",
  "status": 0,
  "outcome1": null,
  "outcome2": ["#|date| #|time| mybucket"]
},
{
  "ID": 4,
  "step": "Copy a file that is smaller than 5MB.",
  "name": "CP",
  "kind": null,
  "operation": "aws s3 cp --no-progress data-04m.txt s3://mybucket",
  "status": 0,
  "outcome1": null,
  "outcome2": ["upload: .*/data-04m.txt to s3://mybucket/data-04m.txt"]
},
{
  "ID": 5,
  "step": "Copy a file that is larger than 5MB.",
  "name": "CP",
  "kind": null,
  "operation": "aws s3 cp --no-progress data-10m.txt s3://mybucket",
  "status": 0,
  "outcome1": null,
  "outcome2": ["upload: .*/data-10m.txt to s3://mybucket/data-10m.txt"]
},
{
  "ID": 6,
  "step": "Copy files in the source directory './datafiles' to 'mybucket'.",
  "name": "SYNC",
  "kind": null,
  "operation": "aws s3 sync --no-progress ./datafiles s3://mybucket",
  "status": 0,
  "outcome1": null,
  "outcome2": ["upload: .*/data-...\\.txt to s3://mybucket/data-...\\.txt",
	       "upload: .*/data-...\\.txt to s3://mybucket/data-...\\.txt",
	       "upload: .*/data-...\\.txt to s3://mybucket/data-...\\.txt",
	       "upload: .*/data-...\\.txt to s3://mybucket/data-...\\.txt"]
},
{
  "ID": 7,
  "step": "Delete a previously copied file in 'mybucket'.",
  "name": "RM",
  "kind": null,
  "operation": "aws s3 rm --no-progresss3 ://mybucket/data-001.txt",
  "status": 0,
  "outcome1": null,
  "outcome2": ["delete: s3://mybucket/data-001.txt"]
},
{
  "ID": 8,
  "step": "Remove 'mybucket', while five files remains in the bucket.",
  "name": "RB",
  "kind": null,
  "operation": "aws s3 rb --no-progresss3 --force s3://mybucket",
  "status": 0,
  "outcome1": null,
  "outcome2": ["delete: s3://mybucket/data-...\\.txt",
	       "delete: s3://mybucket/data-...\\.txt",
	       "delete: s3://mybucket/data-...\\.txt",
	       "delete: s3://mybucket/data-...\\.txt",
	       "delete: s3://mybucket/data-...\\.txt",
	       "remove_bucket: mybucket"],
  "outcome3": "C:\\Users\\k-ryoh>aws s3 rb s3://new-bucket --force\nremove_bucket: new-bucket"
}
]
}
